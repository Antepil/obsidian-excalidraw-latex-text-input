{
  "name": "obsidian-excalidraw-latex-text-input",
  "version": "0.1.6",
  "description": "Enhanced Excalidraw text input with Obsidian LaTeX Suite snippets and inline LaTeX conversion.",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Antepil/obsidian-excalidraw-latex-text-input.git"
  },
  "bugs": {
    "url": "https://github.com/Antepil/obsidian-excalidraw-latex-text-input/issues"
  },
  "homepage": "https://github.com/Antepil/obsidian-excalidraw-latex-text-input#readme",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "excalidraw",
    "latex-suite"
  ],
  "author": "Antepil",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^22.13.14",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2"
  }
}
